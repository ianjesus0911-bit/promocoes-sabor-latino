# OpenAI (usar somente no backend / Netlify Functions)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Meta / Instagram Graph API (não use valores reais no repositório)
META_APP_ID=YOUR_META_APP_ID
META_APP_SECRET=YOUR_META_APP_SECRET
META_REDIRECT_URI=https://your-site.netlify.app/.netlify/functions/instagram-callback

# Opcional: URL pública da aplicação para redirecionar após OAuth
PUBLIC_SITE_URL=https://your-site.netlify.app

# Opcional: versão da API Graph
META_API_VERSION=v20.0
